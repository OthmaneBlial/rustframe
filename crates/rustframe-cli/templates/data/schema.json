{
  "version": 1,
  "tables": [
    {
      "name": "work_items",
      "columns": [
        { "name": "title", "type": "text", "required": true },
        { "name": "summary", "type": "text" },
        { "name": "owner", "type": "text" },
        { "name": "lane", "type": "text", "required": true, "default": "Inbox" },
        { "name": "priority", "type": "text", "required": true, "default": "normal" },
        { "name": "pinned", "type": "boolean", "default": false },
        { "name": "done", "type": "boolean", "default": false }
      ],
      "indexes": [
        { "columns": ["done", "pinned", "updatedAt"] },
        { "columns": ["lane", "updatedAt"] }
      ]
    }
  ]
}
