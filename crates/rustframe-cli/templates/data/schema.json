{
  "version": 1,
  "tables": [
    {
      "name": "notes",
      "columns": [
        { "name": "title", "type": "text", "required": true },
        { "name": "body", "type": "text" },
        { "name": "pinned", "type": "boolean", "default": false }
      ],
      "indexes": [
        { "columns": ["pinned", "title"] }
      ]
    },
    {
      "name": "settings",
      "columns": [
        { "name": "key", "type": "text", "required": true, "unique": true },
        { "name": "value", "type": "json", "required": true }
      ]
    }
  ]
}
