{
  "appId": "research-desk",
  "window": {
    "title": "Research Desk",
    "width": 1480,
    "height": 940
  },
  "security": {
    "model": "local-first"
  },
  "packaging": {
    "version": "0.1.0",
    "description": "Local-first research archive and review workbench",
    "publisher": "RustFrame",
    "homepage": "https://github.com/OthmaneBlial/rustframe",
    "linux": {
      "icon": "assets/icon.svg",
      "categories": ["Office", "Utility"],
      "keywords": ["research", "archive", "desktop", "local-first"]
    },
    "windows": {
      "icon": "assets/icon.svg"
    },
    "macos": {
      "bundleIdentifier": "dev.rustframe.research-desk",
      "icon": "assets/icon.svg"
    }
  },
  "filesystem": {
    "roots": ["workspace", "tools"]
  },
  "shell": {
    "commands": [
      {
        "name": "indexWorkspacePy3",
        "program": "python3",
        "args": ["index_workspace.py", "../workspace"],
        "cwd": "tools",
        "timeoutMs": 15000,
        "maxOutputBytes": 262144
      },
      {
        "name": "indexWorkspacePython",
        "program": "python",
        "args": ["index_workspace.py", "../workspace"],
        "cwd": "tools",
        "timeoutMs": 15000,
        "maxOutputBytes": 262144
      },
      {
        "name": "indexWorkspacePyLauncher",
        "program": "py",
        "args": ["-3", "index_workspace.py", "../workspace"],
        "cwd": "tools",
        "timeoutMs": 15000,
        "maxOutputBytes": 262144
      }
    ]
  }
}
